# PostgreSQL 接続情報
# このファイルをコピーして .env を作成し、実際の値を設定してください。
# .env はコミット対象外です（.gitignore で除外されています）。

# 本番環境 (pro)
PRO_DB_HOST=
PRO_DB_PORT=5432
PRO_DB_NAME=
PRO_DB_USER=
PRO_DB_PASSWORD=

# ステージング環境 (stg)
STG_DB_HOST=
STG_DB_PORT=5432
STG_DB_NAME=
STG_DB_USER=
STG_DB_PASSWORD=

# ローカル Docker 環境 (docker)
DOCKER_DB_HOST=
DOCKER_DB_PORT=15432
DOCKER_DB_NAME=app_development
DOCKER_DB_USER=postgres
DOCKER_DB_PASSWORD=password
